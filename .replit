modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["freetype", "gitFull", "glibcLocales", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "playwright-driver", "tcl", "tk", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Installation Instructions"

[[workflows.workflow]]
name = "Installation Instructions"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "./install-instructions.sh"

[workflows.workflow.metadata]
outputType = "console"
